{
  "id": "railway",
  "name": "Railway",
  "description": "Deployment and project metrics from Railway",
  "credential_fields": [
    {"name": "railway_token", "label": "Railway API Token", "secret": true, "required": true},
    {"name": "railway_project_id", "label": "Project ID", "secret": false, "required": true},
