{
  "connector_type": "aws",
  "display_name": "Amazon Web Services",
  "description": "AWS cloud infrastructure and cost monitoring",
  "auth_config": {
    "required_env_vars": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY"],
    "optional_env_vars": ["AWS_REGION", "AWS_DEFAULT_REGION"],
    "auth_type": "access_key",
    "setup_instructions": {
      "steps": [
        "Go to AWS IAM > Users > Security credentials",
        "Create access key for programmatic access",
        "Set AWS_ACCESS_KEY_ID environment variable",
        "Set AWS_SECRET_ACCESS_KEY environment variable", 
        "Optionally set AWS_REGION for default region"
      ],
      "documentation_url": "https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html"
    },
    "permissions_needed": ["CloudWatchReadOnlyAccess", "CostExplorerServiceRolePolicy"],
    "test_endpoint": "CloudWatch ListMetrics",
    "validation_method": "AWS SDK call to list metrics"
  },
  "credential_fields": {
    "access_key_id": {
      "field_name": "aws_access_key_id",
      "display_name": "AWS Access Key ID",
      "type": "text",
      "required": true,
      "description": "AWS IAM access key ID",
      "placeholder": "AKIAIOSFODNN7EXAMPLE",
      "env_var_pattern": "WORKSPACE_{workspace_id}_AWS_ACCESS_KEY_ID"
    },
    "secret_access_key": {
      "field_name": "aws_secret_access_key",
      "display_name": "AWS Secret Access Key", 
      "type": "password",
      "required": true,
      "description": "AWS IAM secret access key",
      "placeholder": "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY",
      "env_var_pattern": "WORKSPACE_{workspace_id}_AWS_SECRET_ACCESS_KEY"
    },
    "region": {
      "field_name": "aws_default_region",
      "display_name": "Default AWS Region",
      "type": "select",
      "required": false,
      "description": "Default AWS region for API calls",
      "options": ["us-east-1", "us-west-2", "eu-west-1", "ap-southeast-1"],
      "default": "us-east-1",
      "env_var_pattern": "WORKSPACE_{workspace_id}_AWS_REGION"
    }
  },
  "default_config": {
    "track_costs": true,
    "track_usage": true,
    "cost_threshold_alert": 100,
    "enabled": true
  },
  "config_schema": {
    "account_id": {
      "type": "string",
      "required": false,
      "description": "AWS account ID for cost tracking"
    },
    "track_costs": {
      "type": "boolean",
      "default": true,
      "description": "Monitor AWS costs and billing"
    },
    "track_usage": {
      "type": "boolean",
      "default": true,
      "description": "Monitor resource usage metrics"
    },
    "services": {
      "type": "array",
      "items": {"type": "string"},
      "default": ["EC2", "RDS", "Lambda", "S3"],
      "description": "AWS services to monitor"
    },
    "cost_threshold_alert": {
      "type": "number",
      "default": 100,
      "description": "Cost threshold for alerts (USD)"
    }
  }
}