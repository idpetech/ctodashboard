    "jira": {
      "agile_jira_template": {
        "name": "agile_jira_template",
        "type": "jira",
        "config": {
          "track_sprints": true,
          "track_bugs": true,
          "track_story_points": true,
          "default_board": "scrum",
          "enabled": true,
          "project_key": "WEB"
        },
        "auth_config": {
          "required_env_vars": [
            "JIRA_TOKEN",
            "JIRA_EMAIL",
            "JIRA_URL"
          ],
          "auth_type": "api_token",
          "setup_instructions": {
            "steps": [
              "Go to Atlassian Account Settings > Security > API tokens",
              "Create API token for Jira access",
              "Set JIRA_TOKEN environment variable with the token",
              "Set JIRA_EMAIL environment variable with your Atlassian email",
              "Set JIRA_URL environment variable with your Jira instance URL"
            ],
            "documentation_url": "https://support.atlassian.com/atlassian-account/docs/manage-api-tokens-for-your-atlassian-account/"
          },
          "test_endpoint": "/rest/api/3/myself",
          "validation_method": "GET request to Jira API with basic auth (email + token)"
        },
        "credential_fields": {
          "api_token": {
            "field_name": "jira_token",
            "display_name": "Jira API Token",
            "type": "token",
            "required": true,
            "description": "API token from Atlassian account settings",
            "placeholder": "ATxxxxxxxxxxxxxxxxxxxxxx",
            "env_var_pattern": "WORKSPACE_{workspace_id}_JIRA_TOKEN"
          },
          "email": {
            "field_name": "jira_email",
            "display_name": "Jira Email",
            "type": "email",
            "required": true,
            "description": "Your Atlassian account email",
            "placeholder": "user@company.com",
            "env_var_pattern": "WORKSPACE_{workspace_id}_JIRA_EMAIL"
          },
          "instance_url": {
            "field_name": "jira_url",
            "display_name": "Jira Instance URL",
            "type": "url",
            "required": true,
            "description": "Your Jira instance URL",
            "placeholder": "https://yourcompany.atlassian.net",
            "env_var_pattern": "WORKSPACE_{workspace_id}_JIRA_URL"
          }
        },
        "config_schema": {
          "project_key": {
            "type": "string",
            "required": true,
            "description": "Jira project key (e.g., 'PROJ')"
          },
          "track_sprints": {
            "type": "boolean",
            "default": true,
            "description": "Track sprint progress and velocity"
          },
          "track_bugs": {
            "type": "boolean",
            "default": true,
            "description": "Track bug reports and resolution"
          },
          "track_story_points": {
            "type": "boolean",
            "default": true,
            "description": "Track story point estimation and completion"
          },
          "default_board": {
            "type": "string",
            "default": "scrum",
            "options": [
              "scrum",
              "kanban"
            ],
            "description": "Default board type for project management"
          }
        },
        "environment_mapping": {
